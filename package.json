{
  "name": "discord-music-bot",
  "version": "1.0.0",
  "description": "Discord music bot with YouTube streaming, per-guild queues and Docker support.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy:commands": "node src/deploy-commands.js",
    "invite": "node src/generate-invite.js",
    "test": "node --test"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "discord.js": "14.26.4",
    "dotenv": "16.4.7",
    "libsodium-wrappers": "0.7.15",
    "opusscript": "0.1.1"
  }
}
